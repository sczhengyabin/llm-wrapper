# LLM Wrapper 配置文件示例
# 复制此文件为 config.yaml 并修改为你的配置

upstreams:
  # 上游 1: vllm 服务（name 用作唯一标识）
  - name: vllm
    base_url: http://127.0.0.1:30002
    api_key: null  # 如果不需要密钥，设为 null 或空字符串
    enabled: true
    support_chat_completions: true
    support_responses: true
    support_anthropic_messages: false

  # 上游 2: OpenAI 兼容服务
  - name: omlx
    base_url: http://127.0.0.1:8080
    api_key: your-api-key-here
    enabled: true
    support_chat_completions: true
    support_responses: true
    support_anthropic_messages: false

  # 上游 3: Codex / ChatGPT OAuth（由 CLIProxyAPI 管理）
  # token 会缓存到配置文件同级的 .llm-wrapper/cli-proxy-api/ 目录，并由 CLIProxyAPI 自动刷新
  # 注意：Codex OAuth token 的目标是 chatgpt.com 后端，不是 api.openai.com
  - name: codex
    base_url: https://chatgpt.com/backend-api
    auth:
      type: codex_oauth
    enabled: true
    support_chat_completions: true
    support_responses: true
    support_anthropic_messages: true

  # 上游 4: Claude Code / Anthropic OAuth（由 CLIProxyAPI 管理）
  - name: claude
    base_url: https://api.anthropic.com
    auth:
      type: anthropic_oauth
    enabled: true
    support_chat_completions: true
    support_responses: true
    support_anthropic_messages: true

aliases:
  # 别名 1: 简单别名，直接映射到上游模型
  - alias: qwen
    target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
    upstream: vllm
    param_overrides: []
    source: manual  # manual: 手动创建，auto: 点击模型标签自动创建

  # 别名 2: 带参数覆盖的别名
  - alias: qwen-no-thinking
    target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
    upstream: vllm
    param_overrides:
      # default: 只有用户未设置时才应用
      - key: temperature
        value: 0.7
        mode: default
      # 展开 extra_body 到请求体顶层（不保留 extra_body 键）
      - key: extra_body
        value:
          chat_template_kwargs:
            enable_thinking: false
        mode: default
    source: manual

  # Auto Alias 示例（通过 WebUI 点击模型标签自动创建）
  # - alias: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
  #   target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
  #   upstream: vllm
  #   param_overrides: []
  #   source: auto

# 全局配置
# allow_protocol_conversion: false  # 当上游不支持入口协议时，自动转换为上游支持的协议

# 客户端 API Keys（可选）
# 设置后客户端请求 /v1/* 需携带 Authorization: Bearer <key> 或 x-api-key
# 留空或删除此段则不保护客户端 API
# client_api_keys:
#   - name: "本机"
#     key: "your-client-api-key"

# 环境变量
# CONFIG_PATH: 配置文件路径，默认 config.yaml
# BIND_ADDR: 绑定地址，默认 0.0.0.0:3000

# 路由规则说明：
# - 请求中的 model 参数仅匹配 alias 字段
# - target_model 不参与路由匹配，仅用于转发时替换模型名
# - 若需支持直接使用上游模型名调用，需创建对应的 auto alias
