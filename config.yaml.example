# LLM Wrapper 配置文件示例
# 复制此文件为 config.yaml 并修改为你的配置

upstreams:
  # 上游 1: vllm 服务（name 用作唯一标识）
  - name: vllm
    base_url: http://127.0.0.1:30002
    api_key: null  # 如果不需要密钥，设为 null 或空字符串
    enabled: true
    support_openai: true      # 支持 OpenAI 协议 (chat/completions, responses)
    support_anthropic: false   # 不支持 Anthropic 协议 (messages)

  # 上游 2: OpenAI 兼容服务
  - name: omlx
    base_url: http://127.0.0.1:8080
    api_key: your-api-key-here
    enabled: true
    support_openai: true
    support_anthropic: false

  # 上游 3: OAuth Device Code 认证（如 Codex CLI / ChatGPT）
  # OpenAI 使用自定义设备码流程（非标准 RFC 8628），wrapper 会自动识别并适配
  # 登录后 token 会自动缓存到 ~/.llm-wrapper/tokens.json，并自动刷新
  # 注意：Codex OAuth token 的目标是 chatgpt.com 后端，不是 api.openai.com
  - name: openai-oauth
    base_url: https://chatgpt.com/backend-api
    api_type: chatgpt_codex
    auth:
      type: oauth_device
      client_id: "app_EMoamEEZ73f0CkXaXp7hrann"  # OpenAI Codex 默认 Client ID
      device_auth_url: https://auth.openai.com/api/accounts/deviceauth/usercode
      token_url: https://auth.openai.com/api/accounts/deviceauth/token
    enabled: true
    support_openai: true
    support_anthropic: false

aliases:
  # 别名 1: 简单别名，直接映射到上游模型
  - alias: qwen
    target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
    upstream: vllm
    param_overrides: []
    source: manual  # manual: 手动创建，auto: 点击模型标签自动创建

  # 别名 2: 带参数覆盖的别名
  - alias: qwen-no-thinking
    target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
    upstream: vllm
    param_overrides:
      # default: 只有用户未设置时才应用
      - key: temperature
        value: 0.7
        mode: default
      # 展开 extra_body 到请求体顶层（不保留 extra_body 键）
      - key: extra_body
        value:
          chat_template_kwargs:
            enable_thinking: false
        mode: default
    source: manual

  # Auto Alias 示例（通过 WebUI 点击模型标签自动创建）
  # - alias: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
  #   target_model: Qwen/Qwen3.5-122B-A10B-GPTQ-Int4
  #   upstream: vllm
  #   param_overrides: []
  #   source: auto

# 环境变量
# CONFIG_PATH: 配置文件路径，默认 config.yaml
# BIND_ADDR: 绑定地址，默认 0.0.0.0:3000

# 路由规则说明：
# - 请求中的 model 参数仅匹配 alias 字段
# - target_model 不参与路由匹配，仅用于转发时替换模型名
# - 若需支持直接使用上游模型名调用，需创建对应的 auto alias
